{
  "permissions": {
    "defaultMode": "dontAsk"
  },
  "hooks": {
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/auto-continue.js\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/notify-done.sh\"",
            "async": true
          }
        ]
      }
    ]
  }
}
